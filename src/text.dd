class GlyphRect:
    x: i32
    y: i32
    w: i32
    h: i32


class TextSize:
    width: f32
    height: f32


def bit_check(value: u32, bit: i32) -> bool:
    return (value & (u32(1) << bit)) != u32(0)


def glyph_index(code: char) -> i32:
    value = i32(code)
    if value < 32:
        return i32(char(63)) - 32
    index = value - 32
    if index >= DEFAULT_FONT_CHARS_COUNT:
        return i32(char(63)) - 32
    return index


def glyph_rect(index: i32) -> GlyphRect:
    current_line = 0
    current_pos_x = DEFAULT_FONT_CHARS_DIVISOR
    test_pos_x = DEFAULT_FONT_CHARS_DIVISOR
    rect = GlyphRect(x=0, y=0, w=0, h=DEFAULT_FONT_CHARS_HEIGHT)

    for i in range(DEFAULT_FONT_CHARS_COUNT):
        rect.x = current_pos_x
        rect.y = DEFAULT_FONT_CHARS_DIVISOR + current_line * (DEFAULT_FONT_CHARS_HEIGHT + DEFAULT_FONT_CHARS_DIVISOR)
        rect.w = CHARS_WIDTH[i]
        rect.h = DEFAULT_FONT_CHARS_HEIGHT

        test_pos_x += CHARS_WIDTH[i] + DEFAULT_FONT_CHARS_DIVISOR
        if test_pos_x >= DEFAULT_FONT_ATLAS_WIDTH:
            current_line += 1
            current_pos_x = 2 * DEFAULT_FONT_CHARS_DIVISOR + CHARS_WIDTH[i]
            test_pos_x = current_pos_x
            rect.x = DEFAULT_FONT_CHARS_DIVISOR
            rect.y = DEFAULT_FONT_CHARS_DIVISOR + current_line * (DEFAULT_FONT_CHARS_HEIGHT + DEFAULT_FONT_CHARS_DIVISOR)
        else:
            current_pos_x = test_pos_x

        if i == index:
            return rect

    return rect


def font_atlas_pixel_on(x: i32, y: i32) -> bool:
    pixel_index = y * DEFAULT_FONT_ATLAS_WIDTH + x
    word_index = pixel_index / 32
    bit = pixel_index % 32
    return bit_check(DEFAULT_FONT_DATA[word_index], bit)


def draw_glyph(
    renderer: *SDL_Renderer,
    code: char,
    x: f32,
    y: f32,
    scale: f32,
    color: SDL_Color,
):
    index = glyph_index(code)
    rect = glyph_rect(index)
    SDL_SetRenderDrawColor(renderer, color.r, color.g, color.b, color.a)

    pixel = SDL_FRect(x=0.0, y=0.0, w=scale, h=scale)
    for row in range(rect.h):
        for col in range(rect.w):
            if font_atlas_pixel_on(rect.x + col, rect.y + row):
                pixel.x = x + f32(col) * scale
                pixel.y = y + f32(row) * scale
                SDL_RenderFillRect(renderer, &pixel)


def measure_text(text: std.string, point_size: i32) -> TextSize:
    resolved_font_size = std.max(point_size, DEFAULT_FONT_BASE_SIZE)
    scale_factor = f32(resolved_font_size) / f32(DEFAULT_FONT_BASE_SIZE)
    spacing = scale_factor
    line_advance = f32(DEFAULT_FONT_BASE_SIZE + (DEFAULT_FONT_BASE_SIZE / 2)) * scale_factor

    current_width: f32 = 0.0
    max_width: f32 = 0.0
    total_height = f32(resolved_font_size)

    for index: usize in range(text.size()):
        code = text[index]
        if code == char(10):
            max_width = std.max(max_width, current_width)
            current_width = 0.0
            total_height += line_advance
        else:
            glyph = glyph_index(code)
            current_width += f32(CHARS_WIDTH[glyph]) * scale_factor + spacing

    max_width = std.max(max_width, current_width)
    return TextSize(width=max_width, height=total_height)


def draw_text(renderer: *SDL_Renderer, text: std.string, point_size: i32, x: f32, y: f32, color: SDL_Color):
    resolved_font_size = std.max(point_size, DEFAULT_FONT_BASE_SIZE)
    scale_factor = f32(resolved_font_size) / f32(DEFAULT_FONT_BASE_SIZE)
    spacing = scale_factor
    line_advance = f32(DEFAULT_FONT_BASE_SIZE + (DEFAULT_FONT_BASE_SIZE / 2)) * scale_factor

    offset_x: f32 = 0.0
    offset_y: f32 = 0.0
    for index: usize in range(text.size()):
        code = text[index]
        if code == char(10):
            offset_y += line_advance
            offset_x = 0.0
        else:
            glyph = glyph_index(code)
            if code != char(32) and code != char(9):
                draw_glyph(renderer, code, x + offset_x, y + offset_y, scale_factor, color)
            offset_x += f32(CHARS_WIDTH[glyph]) * scale_factor + spacing


def draw_fps(renderer: *SDL_Renderer, fps: i32):
    text = std.to_string(fps)
    text += std.string(" fps")
    shadow = SDL_Color(r=0, g=0, b=0, a=190)
    foreground = SDL_Color(r=238, g=245, b=255, a=255)
    draw_text(renderer, text, 20, 9.0, 9.0, shadow)
    draw_text(renderer, text, 20, 7.0, 7.0, foreground)
